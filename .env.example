# Google Drive koppeling — kopieer naar .env.local en vul je eigen waarden in.
# Zie docs/google-drive-koppeling.md voor setup-instructies.
#
# Voor GitHub Pages deployment: zet deze waarden als repository secrets
# (Settings → Secrets → Actions) en voeg ze toe aan de Build-stap in deploy.yml.

VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/.../exec
VITE_API_KEY=jouw-api-sleutel-hier
